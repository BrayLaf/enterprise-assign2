pipeline{
    agent any
    stages{
        stage('Build'){
            agent{
                docker{
                    image 'node:24.14.0-alpine'
                    reuseNode true
                }
            }
            steps{
                echo 'Building...'
                sh 'npm install'
            }
        }
        stage('Test'){
            agent{
                docker{
                    image 'node:24.14.0-alpine'
                    reuseNode true
                }
            }
            steps{
                echo 'Testing...'
                sh 'npm test'
            }
        }
    }
}