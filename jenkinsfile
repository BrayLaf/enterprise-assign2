pipeline{
    agent any
    stages{
        stage('Build'){
            agent{
                docker{
                    image 'node:24.14.0-alpine'
                    reuseNode true
                    args '--user root'
                }
            }
            steps{
                echo 'Building...'
                sh 'npm install'
            }
        }
        stage('Test'){
            agent{
                docker{
                    image 'node:24.14.0-alpine'
                    reuseNode true
                    args '--user root'
                }
            }
            steps{
                echo 'Testing...'
                sh 'npx react-scripts test --watchAll=false --passWithNoTests'
            }
        }
    }
}